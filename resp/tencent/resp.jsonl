// lyric
MusicJsonCallback({"retcode":0,"code":0,"subcode":0,"lyric":"","trans":""})
{
  lyric: '[ti:天下]\n' +
    '[ar:张杰]\n' +
    '[al:听！我们的歌]\n' +
    '[by:v_emilylu]\n' +
    '[offset:0]\n' +
    '[00:00.00]天下 - 张杰\n' +
    '[00:01.32]词：周毅\n' +
    '[00:01.43]曲：刘吉宁\n' +
    '[00:01.56]编曲：张峰棣/吴牧禅\n' +
    '[00:01.85]制作人：闻震/张杰\n' +
    '[00:02.11]Guitar：程冠琨\n' +
    '[00:02.24]二胡：董小闻\n' +
    '[00:02.42]和音编写/和音：张杰\n' +
    '[00:02.69]混音：周天澈@Studio21A\n' +
    '[00:02.90]母带：Chris Gehringer@Steling Sound NY\n' +
    '[00:03.11]监制/出品人：张杰\n' +
    '[00:03.36]制作/发行：行星文化Planet Culture\n' +
    '[00:03.77]\n' +
    '[00:27.18]烽烟起寻爱似浪淘沙\n' +
    '[00:33.14]\n' +
    '[00:33.86]遇见她如春水映梨花\n' +
    '[00:39.64]\n' +
    '[00:40.53]挥剑断天涯相思轻放下\n' +
    '[00:47.30]梦中我痴痴牵挂\n' +
    '[00:53.22]\n' +
    '[00:54.29]顾不顾将相王侯\n' +
    '[00:55.79]管不管万世千秋\n' +
    '[00:57.40]求只求爱化解\n' +
    '[00:59.21]这万丈红尘纷乱永无休\n' +
    '[01:01.66]爱更爱天长地久\n' +
    '[01:03.19]要更要似水温柔\n' +
    '[01:04.89]谁在乎谁主春秋\n' +
    '[01:07.23]一生有爱何惧风飞沙\n' +
    '[01:10.45]悲白发留不住芳华\n' +
    '[01:14.18]抛去江山如画\n' +
    '[01:15.75]换她笑面如花\n' +
    '[01:17.42]抵过这一生空牵挂\n' +
    '[01:20.60]心若无怨爱恨也随她\n' +
    '[01:23.83]天地大情路永无涯\n' +
    '[01:27.47]只为她袖手天下\n' +
    '[01:33.54]\n' +
    '[02:00.71]顾不顾将相王侯\n' +
    '[02:02.44]管不管万世千秋\n' +
    '[02:04.12]求只求爱化解\n' +
    '[02:05.94]这万丈红尘纷乱永无休\n' +
    '[02:08.25]爱更爱天长地久\n' +
    '[02:09.94]要更要似水温柔\n' +
    '[02:11.59]谁在乎谁主春秋\n' +
    '[02:14.00]一生有爱何惧风飞沙\n' +
    '[02:17.10]悲白发留不住芳华\n' +
    '[02:20.82]抛去江山如画\n' +
    '[02:22.41]换她笑面如花\n' +
    '[02:24.10]抵过这一生空牵挂\n' +
    '[02:27.16]心若无怨爱恨也随她\n' +
    '[02:30.36]天地大情路永无涯\n' +
    '[02:33.98]只为她袖手天下\n' +
    '[02:40.76]一生有爱何惧风飞沙\n' +
    '[02:43.76]悲白发留不住芳华\n' +
    '[02:47.46]抛去江山如画\n' +
    '[02:49.11]换她笑面如花\n' +
    '[02:50.77]抵过这一生空牵挂\n' +
    '[02:53.82]心若无怨爱恨也随她\n' +
    '[02:57.05]天地大情路永无涯\n' +
    '[03:00.63]只为她袖手天下\n' +
    '[03:06.61]\n' +
    '[03:07.30]烽烟起寻爱似浪淘沙\n' +
    '[03:13.11]\n' +
    '[03:13.77]遇见她如春水映梨花\n' +
    '[03:19.77]\n' +
    '[03:20.46]挥剑断天涯相思轻放下\n' +
    '[03:27.27]梦中我痴痴牵挂',
